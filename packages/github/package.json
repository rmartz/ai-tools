{
  "name": "@rmartz/github",
  "version": "0.1.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ai-pr-summary": "./dist/bin/pr-summary.js",
    "ai-pr-diff": "./dist/bin/pr-diff.js",
    "ai-repo-status": "./dist/bin/repo-status.js",
    "ai-pr-comment": "./dist/bin/pr-comment.js",
    "ai-resolve-thread": "./dist/bin/resolve-thread.js",
    "ai-dismiss-thread": "./dist/bin/dismiss-thread.js",
    "ai-discuss": "./dist/bin/discuss.js",
    "ai-discussion-read": "./dist/bin/discussion-read.js",
    "ai-discussion-answer": "./dist/bin/discussion-answer.js",
    "ai-discussion-comment": "./dist/bin/discussion-comment.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmartz/ai-tools.git",
    "directory": "packages/github"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rmartz/agent-runtime": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
