{
  "name": "@rmartz/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:okf": "tsx scripts/check-okf-frontmatter.ts",
    "check:pins": "tsx scripts/check-pins.ts",
    "check:actions": "tsx scripts/check-action-pins.ts",
    "install:skills": "tsx scripts/install-skills.ts",
    "install:clis": "tsx scripts/install-clis.ts",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run check:okf && pnpm run check:pins && pnpm run check:actions && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.12.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.9.4",
    "tsup": "^8.3.0",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
